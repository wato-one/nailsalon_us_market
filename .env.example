DRIVE_SOURCE_DIR=/Users/chinhnguyen/Library/CloudStorage/GoogleDrive-chinhnguyenhue@gmail.com/My Drive/13.MI.Research/Research & Consultant Companies/Nail Salon Research

# Firecrawl (web scraping)
